<!DOCTYPE html>
<html>
<head>
    <title>Adaugă locație</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar">
    <div class="navbar-title">Event Tickets</div>

    <div class="navbar-links">
        <a href="/dashboard">Dashboard</a>
        <a href="/dashboard/events">Evenimente</a>
        <a href="/logout">Logout</a>
    </div>
</nav>

<div class="form-card card">
    <h1>Adaugă locație</h1>

    <form action="/dashboard/venues" method="POST">

        <div class="form-group">
            <label>Nume locație</label>
            <input
                type="text"
                name="name"
                placeholder="BT Arena"
                required
            >
        </div>

        <div class="form-group">
            <label>Adresă / oraș</label>
            <input
                type="text"
                name="location"
                placeholder="Cluj-Napoca, România"
                required
            >
        </div>

        <div class="form-group">
            <label>Capacitate</label>
            <input
                type="number"
                name="capacity"
                placeholder="10000"
                required
            >
        </div>

        <div class="form-group">
            <label>Latitudine</label>
            <input
                type="number"
                step="any"
                name="latitude"
                placeholder="46.7666"
                required
            >
        </div>

        <div class="form-group">
            <label>Longitudine</label>
            <input
                type="number"
                step="any"
                name="longitude"
                placeholder="23.5729"
                required
            >
        </div>

        <button class="btn btn-primary" type="submit">
            Salvează locația
        </button>

    </form>
</div>

</body>
</html>