<!DOCTYPE html>
<html>
<head>
    <title><%= event.title %></title>

    <link rel="stylesheet" href="/css/style.css">

    <link
        rel="stylesheet"
        href="https://unpkg.com/leaflet/dist/leaflet.css"
    >
</head>
<body>

<nav class="navbar">
    <div class="navbar-title">Event Tickets</div>

    <div class="navbar-links">
        <a href="/dashboard">Dashboard</a>
        <a href="/dashboard/events">Evenimente</a>
        <a href="/dashboard/my-tickets">Biletele mele</a>
        <a href="/logout">Logout</a>
    </div>
</nav>

<div class="page">

    <a class="btn btn-secondary" href="/dashboard/events">
        Înapoi la evenimente
    </a>

    <div class="details-layout">

        <div class="card detail-box">
            <span class="badge">Eveniment live</span>

            <h1><%= event.title %></h1>

            <br>

            <p>
                <strong>Artist:</strong>
                <%= event.artist %>
            </p>

            <p>
                <strong>Descriere:</strong>
                <%= event.description %>
            </p>

            <p>
                <strong>Data:</strong>
                <%= event.date.toLocaleDateString("ro-RO") %>
            </p>

            <p>
                <strong>Locație:</strong>
                <% if (event.venue) { %>
                    <%= event.venue.name %>, <%= event.venue.location %>
                <% } else { %>
                    Locație necunoscută
                <% } %>
            </p>

            <p>
                <strong>Preț:</strong>
                <%= event.ticketPrice %> RON
            </p>

            <p>
                <strong>Bilete disponibile:</strong>
                <%= event.availableTickets %>
            </p>

            <% if (event.availableTickets > 0) { %>
                <form action="/dashboard/events/<%= event._id %>/buy" method="POST">
                    <button class="btn btn-primary" type="submit">
                        Cumpără bilet
                    </button>
                </form>
            <% } else { %>
                <p>Nu mai sunt bilete disponibile.</p>
            <% } %>
        </div>

        <div class="card">
            <h2>Locația evenimentului</h2>

            <% if (event.venue && event.venue.latitude && event.venue.longitude) { %>
                <div id="map"></div>
            <% } else { %>
                <p class="empty-message">
                    Nu există coordonate pentru această locație.
                </p>
            <% } %>
        </div>

    </div>

</div>

<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

<% if (event.venue && event.venue.latitude && event.venue.longitude) { %>
    <script>
        const latitude = <%= event.venue.latitude %>;
        const longitude = <%= event.venue.longitude %>;

        const map = L.map("map").setView([latitude, longitude], 15);

        L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
            maxZoom: 19,
            attribution: "© OpenStreetMap"
        }).addTo(map);

        L.marker([latitude, longitude])
            .addTo(map)
            .bindPopup("<%= event.venue.name %><br><%= event.venue.location %>")
            .openPopup();
    </script>
<% } %>

</body>
</html>