<!DOCTYPE html>
<html>
<head>
    <title>Biletele mele</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar">
    <div class="navbar-title">Event Tickets</div>

    <div class="navbar-links">
        <a href="/dashboard">Dashboard</a>
        <a href="/dashboard/events">Evenimente</a>
        <a href="/logout">Logout</a>
    </div>
</nav>

<div class="page">
    <div class="card">
        <h1>Biletele mele</h1>
    </div>

    <br>

    <% if (tickets.length === 0) { %>

        <div class="empty-message">
            Nu ai cumpărat niciun bilet.
        </div>

    <% } else { %>

        <% tickets.forEach(ticket => { %>

            <div class="ticket-card">
                <h2><%= ticket.event.title %></h2>

                <p>
                    <strong>Artist:</strong>
                    <%= ticket.event.artist %>
                </p>

                <p>
                    <strong>Data:</strong>
                    <%= ticket.event.date.toLocaleDateString("ro-RO") %>
                </p>

                <p>
                    <strong>Locație:</strong>
                    <% if (ticket.event.venue) { %>
                        <%= ticket.event.venue.name %>
                    <% } else { %>
                        Locație necunoscută
                    <% } %>
                </p>

                <p>
                    <strong>Cumpărat la:</strong>
                    <%= ticket.purchaseDate.toLocaleDateString("ro-RO") %>
                </p>
            </div>

        <% }) %>

    <% } %>
</div>

</body>
</html>