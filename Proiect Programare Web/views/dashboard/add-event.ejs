<!DOCTYPE html>
<html>
<head>
    <title>Adaugă eveniment</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar">
    <div class="navbar-title">Event Tickets</div>

    <div class="navbar-links">
        <a href="/dashboard">Dashboard</a>
        <a href="/dashboard/events">Evenimente</a>
        <a href="/logout">Logout</a>
    </div>
</nav>

<div class="form-card card">
    <h1>Adaugă eveniment</h1>

    <% if (venues.length === 0) { %>

        <p>Nu există locații. Adaugă mai întâi o locație.</p>
        <br>
        <a class="btn btn-primary" href="/dashboard/venues/new">
            Adaugă locație
        </a>

    <% } else { %>

        <form action="/dashboard/events" method="POST">

            <div class="form-group">
                <label>Titlu eveniment</label>
                <input type="text" name="title" placeholder="Concert Coldplay" required>
            </div>

            <div class="form-group">
                <label>Artist</label>
                <input type="text" name="artist" placeholder="Coldplay" required>
            </div>

            <div class="form-group">
                <label>Descriere</label>
                <textarea name="description" placeholder="Descriere eveniment" required></textarea>
            </div>

            <div class="form-group">
                <label>Dată</label>
                <input type="date" name="date" required>
            </div>

            <div class="form-group">
                <label>Locație</label>
                <select name="venue" required>
                    <% venues.forEach(venue => { %>
                        <option value="<%= venue._id %>">
                            <%= venue.name %> - <%= venue.location %>
                        </option>
                    <% }) %>
                </select>
            </div>

            <div class="form-group">
                <label>Număr total bilete</label>
                <input type="number" name="totalTickets" placeholder="1000" required>
            </div>

            <div class="form-group">
                <label>Preț bilet</label>
                <input type="number" name="ticketPrice" placeholder="250" required>
            </div>

            <div class="form-group">
                <label>Imagine URL</label>
                <input type="text" name="imageUrl" placeholder="https://...">
            </div>

            <button class="btn btn-primary" type="submit">
                Salvează eveniment
            </button>

        </form>

    <% } %>
</div>

</body>
</html>