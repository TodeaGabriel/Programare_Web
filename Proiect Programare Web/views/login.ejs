<!DOCTYPE html>
<html>
<head>
    <title>Login</title>
</head>
<body>

<h1>Login</h1>

<form action="/login" method="POST">

    <label>Email</label>
    <input
        type="email"
        name="email"
        required
    >

    <br><br>

    <label>Password</label>
    <input
        type="password"
        name="password"
        required
    >

    <br><br>

    <button type="submit">
        Login
    </button>

</form>

<a href="/register">
    Create account
</a>

</body>
</html>